generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum JobRunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum PushChannel {
  APP
  WECHAT
  SMS
  EMAIL
}

model SourceSnapshot {
  id            BigInt   @id @default(autoincrement())
  sourceCode    String   @db.VarChar(64)
  snapshotDate  DateTime @db.Date
  payload       Json
  checksum      String?  @db.VarChar(128)
  createdAt     DateTime @default(now())

  @@unique([sourceCode, snapshotDate])
  @@index([snapshotDate])
}

model MarketDailyBar {
  id            BigInt   @id @default(autoincrement())
  tradeDate     DateTime @db.Date
  stockCode     String   @db.VarChar(16)
  stockName     String   @db.VarChar(64)
  sectorCode    String?  @db.VarChar(32)
  sectorName    String?  @db.VarChar(64)
  openPrice     Decimal? @db.Decimal(12, 4)
  closePrice    Decimal? @db.Decimal(12, 4)
  highPrice     Decimal? @db.Decimal(12, 4)
  lowPrice      Decimal? @db.Decimal(12, 4)
  turnoverRate  Decimal? @db.Decimal(10, 4)
  volumeRatio   Decimal? @db.Decimal(10, 4)
  amount        Decimal? @db.Decimal(18, 2)
  extraMetrics  Json?
  createdAt     DateTime @default(now())

  @@unique([tradeDate, stockCode])
  @@index([stockCode, tradeDate])
  @@index([sectorCode, tradeDate])
}

model CandidatePoolSnapshot {
  id             BigInt            @id @default(autoincrement())
  snapshotDate   DateTime          @db.Date
  strategyCode   String            @db.VarChar(64)
  versionTag     String            @db.VarChar(64)
  marketSummary  Json?
  createdAt      DateTime          @default(now())
  candidateItems CandidateSignal[]

  @@unique([snapshotDate, strategyCode, versionTag])
}

model CandidateSignal {
  id                  BigInt                @id @default(autoincrement())
  snapshotId          BigInt
  stockCode           String                @db.VarChar(16)
  stockName           String                @db.VarChar(64)
  sectorName          String?               @db.VarChar(64)
  signalLevel         String                @db.VarChar(32)
  score               Decimal               @db.Decimal(8, 2)
  riskScore           Decimal?              @db.Decimal(8, 2)
  holdingWindow       String?               @db.VarChar(32)
  driverSummary       String?               @db.VarChar(255)
  tags                Json?
  createdAt           DateTime              @default(now())
  snapshot            CandidatePoolSnapshot @relation(fields: [snapshotId], references: [id])

  @@index([snapshotId])
  @@index([stockCode])
  @@index([signalLevel])
}

model DiagnosisSnapshot {
  id               BigInt   @id @default(autoincrement())
  stockCode        String   @db.VarChar(16)
  tradeDate        DateTime @db.Date
  versionTag       String   @db.VarChar(64)
  totalScore       Decimal  @db.Decimal(8, 2)
  biasLabel        String?  @db.VarChar(32)
  trendLabel       String?  @db.VarChar(32)
  riskLabel        String?  @db.VarChar(32)
  summary          Json
  factors          Json?
  createdAt        DateTime @default(now())

  @@unique([stockCode, tradeDate, versionTag])
  @@index([tradeDate])
}

model ReviewSnapshot {
  id                 BigInt   @id @default(autoincrement())
  reviewDate         DateTime @db.Date
  strategyCode       String   @db.VarChar(64)
  candidateCount     Int
  hitCount           Int
  winRate            Decimal? @db.Decimal(8, 4)
  excessReturn       Decimal? @db.Decimal(10, 4)
  maxDrawdown        Decimal? @db.Decimal(10, 4)
  detailPayload      Json?
  createdAt          DateTime @default(now())

  @@unique([reviewDate, strategyCode])
}

model AppUser {
  id             BigInt   @id @default(autoincrement())
  userCode       String   @unique @db.VarChar(64)
  mobile         String?  @unique @db.VarChar(32)
  nickname       String?  @db.VarChar(64)
  passwordHash   String?  @db.VarChar(255)
  roleCode       String   @default("USER") @db.VarChar(32)
  membershipPlan String?  @db.VarChar(32)
  status         String   @default("TRIAL") @db.VarChar(32)
  lastLoginAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  pushTasks      PushTask[]
  sessions       UserSession[]
  watchlistItems WatchlistItem[]
}

model UserSession {
  id         BigInt   @id @default(autoincrement())
  userId     BigInt
  token      String   @unique @db.VarChar(128)
  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())
  user       AppUser  @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
  @@index([token, revokedAt])
}

model WatchlistItem {
  id         BigInt   @id @default(autoincrement())
  userId     BigInt?
  stockCode  String   @db.VarChar(16)
  stockName  String   @db.VarChar(64)
  sectorName String?  @db.VarChar(64)
  status     String   @db.VarChar(32)
  statusKey  String   @db.VarChar(32)
  reason     String?  @db.VarChar(255)
  advice     String?  @db.VarChar(255)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       AppUser? @relation(fields: [userId], references: [id])

  @@index([userId, sortOrder])
  @@index([stockCode])
}

model ModelRuleConfig {
  id         BigInt   @id @default(autoincrement())
  ruleCode   String   @unique @db.VarChar(64)
  name       String   @db.VarChar(128)
  action     String   @db.VarChar(32)
  note       String?  @db.VarChar(255)
  scene      String?  @db.VarChar(64)
  versionTag String?  @db.VarChar(64)
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([scene, enabled])
}

model PushTask {
  id             BigInt      @id @default(autoincrement())
  userId         BigInt?
  channel        PushChannel
  templateCode   String      @db.VarChar(64)
  businessKey    String?     @db.VarChar(128)
  payload        Json
  sentAt         DateTime?
  createdAt      DateTime    @default(now())
  user           AppUser?    @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([channel, createdAt])
}

model JobRun {
  id            BigInt       @id @default(autoincrement())
  jobCode       String       @db.VarChar(64)
  queueName     String       @db.VarChar(64)
  status        JobRunStatus @default(PENDING)
  scheduledAt   DateTime?
  startedAt     DateTime?
  finishedAt    DateTime?
  durationMs    Int?
  traceId       String?      @db.VarChar(128)
  resultSummary String?      @db.VarChar(255)
  errorMessage  String?      @db.VarChar(1000)
  payload       Json?
  createdAt     DateTime     @default(now())

  @@index([jobCode, createdAt])
  @@index([queueName, status])
}

model PaymentOrder {
  id            BigInt   @id @default(autoincrement())
  orderNo       String   @unique @db.VarChar(64)
  userId        BigInt   @db.BigInt
  userCode      String   @db.VarChar(64)
  planCode      String   @db.VarChar(32)
  planName      String   @db.VarChar(64)
  amount        Decimal  @db.Decimal(10, 2)
  paymentMethod String   @default("wechat") @db.VarChar(32)
  status        String   @default("PENDING") @db.VarChar(32)
  transactionId String?  @db.VarChar(128)
  paidAt        DateTime?
  expiresAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userCode, createdAt])
  @@index([orderNo])
}